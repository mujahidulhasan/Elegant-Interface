{
  "framework": "vite",
  "buildCommand": "cd artifacts/clipvlt && pnpm install --no-frozen-lockfile && pnpm build",
  "outputDirectory": "artifacts/clipvlt/dist",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "PORT": "3000",
    "BASE_PATH": "/"
  }
}
